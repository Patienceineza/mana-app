EXPO_PUBLIC_API_URL=http://192.168.1.65:8080

# Google Sign-In (buyers only). Create OAuth 2.0 client IDs in the same
# Google Cloud project as the backend's GOOGLE_CLIENT_IDS — one per platform
# you ship. Leave a platform blank if you haven't configured it yet.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
